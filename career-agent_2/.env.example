# ---- Required ----
# Your Anthropic API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ---- Models (defaults are sensible, override if you like) ----
# Used for high-stakes writing/reviewing (CV, cover letter, interview prep)
CAREER_AGENT_MODEL_QUALITY=claude-sonnet-5
# Used for cheap/fast tasks (search ranking, quick fit scoring)
CAREER_AGENT_MODEL_FAST=claude-haiku-4-5-20251001

# ---- Job board APIs (all optional — the "Apply" flow works with none of these,
#      since you paste a specific job link. These only power broad "Search" tab.) ----

# Adzuna: free key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Two-letter country code Adzuna uses, e.g. us, gb, ca, au, de
ADZUNA_COUNTRY=us

# USAJobs: free key at https://developer.usajobs.gov/ (requires the email you register with)
USAJOBS_API_KEY=
USAJOBS_USER_AGENT_EMAIL=

# RemoteOK and Remotive are public and need no key.

# JSearch (RapidAPI/OpenWeb Ninja): aggregates LinkedIn, Indeed, Glassdoor, ZipRecruiter
# via Google for Jobs. Optional, has a free tier. Sign up at:
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# A real contact email is used as a polite User-Agent when fetching job pages you link to.
CAREER_AGENT_CONTACT_EMAIL=you@example.com

# Where LaTeX binaries live if not on PATH (leave blank if `pdflatex`/`xelatex` are on PATH already)
LATEX_BIN_DIR=

# ---- Running on a remote VM (e.g. AWS EC2) instead of your own laptop ----
# Leave both blank for normal laptop use (binds to 127.0.0.1, no auth prompt).
# For a VM: set CAREER_AGENT_HOST=0.0.0.0 and set BOTH basic auth values below —
# this app holds your profile data and can spend your Anthropic API credits,
# so don't expose it with CAREER_AGENT_HOST=0.0.0.0 and no auth set.
CAREER_AGENT_HOST=127.0.0.1
CAREER_AGENT_PORT=8420
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
