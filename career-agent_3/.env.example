# ============================================================
# Career Agent — configuration
# ============================================================

# ---- Required: Groq API Key (FREE — no credit card needed) ----
# 1. Go to https://console.groq.com/
# 2. Sign up with Google/GitHub/email
# 3. Click "API Keys" in the left menu → "Create API Key"
# 4. Copy the key (starts with gsk_...) and paste it below
GROQ_API_KEY=gsk_...

# ---- Models (defaults are good — only change if you want to experiment) ----
# Quality model: used for CV writing, cover letters, fit evaluation
CAREER_AGENT_MODEL_QUALITY=llama-3.3-70b-versatile
# Fast model: used for quick tasks
CAREER_AGENT_MODEL_FAST=llama-3.1-8b-instant

# ---- Job board APIs (all optional) ----
# The Apply tab works with none of these — they only power the Search tab.

# Adzuna: free key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in

# USAJobs (US federal jobs only): free at https://developer.usajobs.gov/
USAJOBS_API_KEY=
USAJOBS_USER_AGENT_EMAIL=

# JSearch: aggregates LinkedIn/Indeed/Glassdoor via Google for Jobs.
# Free tier (200 req/month) at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# ---- Contact email (used as a polite User-Agent when fetching job pages) ----
CAREER_AGENT_CONTACT_EMAIL=you@example.com

# ---- LaTeX (optional — needed only if you want PDF output) ----
# Leave blank if pdflatex is on your PATH already.
# Ubuntu install: sudo apt-get install texlive texlive-latex-extra texlive-fonts-recommended
LATEX_BIN_DIR=

# ---- EC2 / VM deployment (leave defaults for laptop use) ----
# To expose on a VM: set HOST to 0.0.0.0 and set both auth values below.
CAREER_AGENT_HOST=127.0.0.1
CAREER_AGENT_PORT=8420
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
